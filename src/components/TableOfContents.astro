---
// src/components/TableOfContents.astro
const { headings } = Astro.props;

// 目次に表示する見出しの深さを指定（ここでは h2 と h3 のみ抽出）
const filteredHeadings = headings.filter((heading: any) => heading.depth > 1 && heading.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <details class="collapse collapse-arrow bg-base-200 mb-8 border rounded-box shadow-sm">
    <summary class="collapse-title text-lg font-medium">
      目次
    </summary>
    <div class="collapse-content">
      <ul class="menu menu-sm w-full">
        {filteredHeadings.map((heading: any) => (
          <li>
            <a 
              href={`#${heading.slug}`} 
              class={`hover:text-primary ${heading.depth === 3 ? "ml-4 text-sm" : "font-semibold"}`}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </details>
)}