---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import WorkCard from '../../../components/WorkCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const works = await getCollection('works', ({ data }) => !data.draft);
  const allTags = [...new Set(works.flatMap(w => w.data.tags))].filter(Boolean);

  return allTags.map(tag => ({
    params: { tag },
    props: {
      tag,
      works: works
        .filter(w => w.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

interface Props {
  tag:   string;
  works: Awaited<ReturnType<typeof getCollection<'works'>>>;
}

const { tag, works } = Astro.props;
---

<BaseLayout title={`#${tag} の作品`} description={`タグ「${tag}」の作品一覧`}>
  <div class="mb-8">
    <a href="/works" class="text-sm text-slate-400 hover:text-indigo-500 transition-colors mb-3 inline-block">
      ← Works に戻る
    </a>
    <h1 class="text-2xl font-bold text-slate-900">
      <span class="text-indigo-500">#</span>{tag}
    </h1>
    <p class="text-sm text-slate-400 mt-1">{works.length} 件の作品</p>
  </div>

  {works.length === 0
    ? <p class="text-sm text-slate-400">このタグの作品はまだありません。</p>
    : (
      <div class="flex flex-col gap-3">
        {works.map(work => <WorkCard {work} />)}
      </div>
    )
  }
</BaseLayout>
