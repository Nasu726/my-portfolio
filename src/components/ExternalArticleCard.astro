---
import type { ExternalArticle } from '../lib/externalArticles';
import type { ExternalBlogService } from '../config';
import { formatDate, isNew } from '../lib/utils';
import { SITE } from '../config';

interface Props {
  article: ExternalArticle;
}

const { article } = Astro.props;
const { title, description, pubDate, url, tags, source } = article;
const showNew = isNew(pubDate);

const SOURCE_BADGE: Record<ExternalBlogService, { label: string; cls: string }> = {
  qiita: { label: 'Qiita', cls: 'bg-green-100 text-green-700' },
  zenn:  { label: 'Zenn',  cls: 'bg-blue-100  text-blue-700'  },
};
const badge = SOURCE_BADGE[source];
---

<article class="group relative bg-white rounded-2xl border border-base-300 hover:border-primary/40 hover:shadow-md transition-all duration-200 p-5">
  {/* stretched link（外部リンク） */}
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="absolute inset-0 rounded-2xl z-0"
    aria-label={title}
  ></a>

  {/* ソースバッジ + 外部リンクアイコン */}
  <div class="flex items-center justify-between mb-2">
    <span class={`relative z-10 text-xs font-medium px-2 py-0.5 rounded-full ${badge.cls}`}>
      {badge.label}
    </span>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-base-content/30 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </div>

  {/* タイトル */}
  <h2 class="font-bold text-base leading-snug mb-2 group-hover:text-primary transition-colors line-clamp-2">
    {showNew && <span class="inline-block badge badge-primary badge-xs mr-1.5 align-middle">New</span>}
    {title}
  </h2>

  {/* 概要 */}
  <p class="text-sm text-base-content/60 line-clamp-2 mb-4">{description}</p>

  {/* タグ */}
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mb-4">
      {tags.map((tag) => (
        <a
          href={`/blog/tag/${tag}`}
          class="relative z-10 text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full hover:bg-primary/20 transition-colors"
        >
          #{tag}
        </a>
      ))}
    </div>
  )}

  {/* 著者行 */}
  <div class="flex items-center gap-2">
    <img
      src="/nasucat.webp"
      alt={SITE.author}
      class="w-6 h-6 rounded-full object-cover flex-shrink-0"
      loading="lazy"
    />
    <span class="text-xs text-base-content/60">{SITE.author}</span>
    <span class="text-xs text-base-content/30">·</span>
    <time class="text-xs text-base-content/50">{formatDate(pubDate)}</time>
  </div>
</article>
