---
import type { CollectionEntry } from 'astro:content';
import { isNew } from '../lib/utils';

interface Props {
  work: CollectionEntry<'works'>;
}

const { work } = Astro.props;
const { title, description, pubDate, projectUrl, heroImage, badge, tags } = work.data;
const showNew = isNew(pubDate);

const isGitHub = projectUrl.includes('github.com');
const iconSrc  = heroImage ?? (isGitHub ? '/github-mark.webp' : null);
const initial  = title.charAt(0).toUpperCase();
---

<article class="group relative bg-white border border-slate-200 rounded-xl p-5 hover:border-indigo-200 hover:shadow-sm transition-all duration-150">
  <a href={projectUrl} target="_blank" rel="noopener noreferrer" class="absolute inset-0 rounded-xl" aria-label={title}></a>

  <div class="flex items-start gap-4">
    <!-- アイコン -->
    <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-slate-100 flex items-center justify-center overflow-hidden border border-slate-200">
      {iconSrc
        ? <img src={iconSrc} alt={title} class="w-full h-full object-cover" loading="lazy" />
        : <span class="font-bold text-slate-500 text-lg">{initial}</span>
      }
    </div>

    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <h2 class="font-semibold text-slate-800 group-hover:text-indigo-600 transition-colors truncate">
          {title}
        </h2>
        {(badge || showNew) && (
          <span class="flex-shrink-0 text-xs bg-indigo-100 text-indigo-600 px-1.5 py-0.5 rounded font-medium">
            {badge ?? 'New'}
          </span>
        )}
      </div>

      {description && (
        <p class="text-sm text-slate-500 line-clamp-2 mb-2">{description}</p>
      )}

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <a href={`/works/tag/${tag}`} class="relative z-10 text-xs text-slate-400 hover:text-slate-700 transition-colors">
              #{tag}
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- 外部リンクアイコン -->
    <svg class="w-4 h-4 flex-shrink-0 text-slate-300 group-hover:text-indigo-400 transition-colors mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
    </svg>
  </div>
</article>
