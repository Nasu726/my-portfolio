---
/**
 * 作品一覧ページです。タグによるフィルタリングが可能です。
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkCard from '../../components/WorkCard.astro';
import { getCollection } from 'astro:content';
import { collectTags } from '../../lib/utils';

// Works を取得（draft 除外、日付降順）
const works = (await getCollection('works', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// タグ一覧を生成
const allTags = collectTags(works.map((w) => w.data.tags));
---

<BaseLayout title="Works" description="作品一覧">
  <div class="mb-6">
    <h1 class="text-3xl font-bold mb-2">Works</h1>
  </div>

  {/* タグフィルター */}
  {allTags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-6">
      {allTags.map((tag) => (
        <a href={`/works/tag/${tag}`} class="badge badge-outline hover:badge-secondary transition-colors">
          #{tag}
        </a>
      ))}
    </div>
  )}

  {/* 作品一覧 */}
  {works.length === 0 ? (
    <div class="alert">
      <p>まだ作品がありません。新しいプロジェクトの発表をお待ちください。</p>
    </div>
  ) : (
    <div class="flex flex-col gap-3">
      {works.map((work) => <WorkCard {work} />)}
    </div>
  )}
</BaseLayout>
