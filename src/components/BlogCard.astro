---
import type { CollectionEntry } from 'astro:content';
import { formatDate, isNew } from '../lib/utils';
import { SITE } from '../config';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const slug    = post.id;
const showNew = isNew(pubDate);
---

<article class="group relative bg-white border border-slate-200 rounded-xl p-5 hover:border-indigo-200 hover:shadow-sm transition-all duration-150">
  <a href={`/blog/${slug}`} class="absolute inset-0 rounded-xl" aria-label={title}></a>

  <h2 class="font-semibold text-slate-800 leading-snug mb-2 group-hover:text-indigo-600 transition-colors line-clamp-2">
    {showNew && (
      <span class="inline-block text-xs bg-indigo-100 text-indigo-600 px-1.5 py-0.5 rounded mr-1.5 align-middle font-medium">New</span>
    )}
    {title}
  </h2>

  {description && (
    <p class="text-sm text-slate-500 line-clamp-2 mb-3">{description}</p>
  )}

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-3">
      {tags.map(tag => (
        <a href={`/blog/tag/${tag}`} class="relative z-10 text-xs text-indigo-500 hover:text-indigo-700 transition-colors">
          #{tag}
        </a>
      ))}
    </div>
  )}

  <div class="flex items-center gap-2 text-xs text-slate-400">
    <img src="/nasucat.webp" alt={SITE.author} class="w-5 h-5 rounded-full object-cover flex-shrink-0" loading="lazy" />
    <span>{SITE.author}</span>
    <span>·</span>
    <time>{formatDate(pubDate)}</time>
  </div>
</article>
