---
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../lib/utils';
import { SITE } from '../config';
import type { MarkdownHeading } from 'astro';

interface Props {
  frontmatter: {
    title:       string;
    description: string;
    pubDate:     Date;
    heroImage?:  string;
    tags?:       string[];
  };
  ogImageOverride?: string;
  headings?:        MarkdownHeading[];
  readingTime?:     number;
}

const { frontmatter, ogImageOverride, headings = [], readingTime } = Astro.props;
const { title, description, pubDate, heroImage, tags = [] } = frontmatter;

const ogImage = ogImageOverride || (heroImage?.trim() ? heroImage : SITE.defaultOgImage);

// h2・h3 のみ目次に表示（h1 は記事タイトルなので除外）
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<BaseLayout {title} {description} {ogImage}>
  <article class="prose prose-base max-w-none prose-img:mx-auto prose-a:text-primary">

    {/* ヒーロー画像 */}
    {heroImage?.trim() && (
      <img
        src={heroImage}
        alt={title}
        class="w-full max-h-64 object-contain rounded-xl mb-6 not-prose"
        loading="eager"
      />
    )}

    {/* タイトル */}
    <h1 class="text-3xl font-bold mb-2 not-prose">{title}</h1>

    {/* 日付 + 読了目安 */}
    <div class="flex items-center gap-2 text-sm text-base-content/50 not-prose mb-3">
      <time>{formatDate(pubDate)}</time>
      {readingTime && (
        <>
          <span>·</span>
          <span>約 {readingTime} 分で読めます</span>
        </>
      )}
    </div>

    {/* タグ */}
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-5 not-prose">
        {tags.map((tag) => (
          <a
            href={`/blog/tag/${tag}`}
            class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full hover:bg-primary/20 transition-colors"
          >
            #{tag}
          </a>
        ))}
      </div>
    )}

    {/* 目次 */}
    {tocHeadings.length >= 2 && (
      <details class="mb-6 p-4 bg-base-200 rounded-xl not-prose" open>
        <summary class="cursor-pointer font-bold text-sm select-none text-base-content/80">
          目次
        </summary>
        <nav class="mt-3 space-y-1">
          {tocHeadings.map((h) => (
            <a
              href={`#${h.slug}`}
              class:list={[
                'block text-sm transition-colors hover:text-primary',
                h.depth === 2
                  ? 'font-medium text-base-content/70'
                  : 'pl-4 text-base-content/50 text-xs',
              ]}
            >
              {h.text}
            </a>
          ))}
        </nav>
      </details>
    )}

    <div class="divider not-prose my-4"></div>

    {/* 本文 */}
    <slot />
  </article>

  {/* コードブロックのコピーボタン */}
  <script>
    document.querySelectorAll('pre').forEach((block) => {
      if (!block.parentNode) return;
      if (block.getAttribute('data-language') === 'mermaid' || block.classList.contains('mermaid')) return;

      const wrapper = document.createElement('div');
      wrapper.className = 'relative group mb-4';
      block.parentNode.insertBefore(wrapper, block);
      wrapper.appendChild(block);

      const btn = document.createElement('button');
      btn.className = 'absolute top-2 right-2 px-2 py-1 bg-slate-700/80 hover:bg-slate-600 text-white text-xs rounded opacity-0 group-hover:opacity-100 transition-opacity z-10';
      btn.textContent = 'Copy';

      btn.addEventListener('click', async () => {
        const code = block.querySelector('code')?.innerText || '';
        try {
          await navigator.clipboard.writeText(code);
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
        } catch {
          btn.textContent = 'Error';
        }
      });

      wrapper.appendChild(btn);
    });
  </script>
</BaseLayout>
