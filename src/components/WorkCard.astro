---
import type { CollectionEntry } from 'astro:content';
import { formatDate, isNew } from '../lib/utils';

interface Props {
  work: CollectionEntry<'works'>;
}

const { work } = Astro.props;
const { title, description, pubDate, projectUrl, badge, heroImage, tags } = work.data;
const showNew   = isNew(pubDate);
const isGitHub  = projectUrl.includes('github.com');
const iconSrc   = heroImage ?? (isGitHub ? '/github-mark.webp' : null);
---

<article class="group relative bg-white rounded-2xl border border-base-300 hover:border-secondary/40 hover:shadow-md transition-all duration-200 p-5">
  {/* stretched link（外部サイトへ） */}
  <a
    href={projectUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="absolute inset-0 rounded-2xl z-0"
    aria-label={title}
  ></a>

  {/* ヘッダー行：アイコン + プロジェクト名 */}
  <div class="flex items-start gap-3 mb-3">
    <div class="w-10 h-10 rounded-xl bg-base-200 flex-shrink-0 overflow-hidden flex items-center justify-center">
      {iconSrc ? (
        <img
          src={iconSrc}
          alt={title}
          class="w-full h-full object-contain p-1.5"
          loading="lazy"
        />
      ) : (
        <span class="font-bold text-lg text-primary">{title[0]}</span>
      )}
    </div>

    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-1.5 flex-wrap">
        <h2 class="font-bold text-base leading-snug group-hover:text-secondary transition-colors">
          {title}
        </h2>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-base-content/30 group-hover:text-secondary/60 flex-shrink-0 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </div>
      <div class="flex items-center gap-1.5 flex-wrap mt-0.5">
        {showNew && <span class="badge badge-primary badge-xs">New</span>}
        {badge  && <span class="badge badge-secondary badge-xs">{badge}</span>}
      </div>
    </div>
  </div>

  {/* 説明 */}
  <p class="text-sm text-base-content/60 line-clamp-3 mb-3">{description}</p>

  {/* タグ + 日付 */}
  <div class="flex flex-wrap items-center gap-1.5">
    {tags.map((tag) => (
      <a
        href={`/works/tag/${tag}`}
        class="relative z-10 text-xs bg-secondary/10 text-secondary px-2 py-0.5 rounded-full hover:bg-secondary/20 transition-colors"
      >
        #{tag}
      </a>
    ))}
    <time class="text-xs text-base-content/40 ml-auto">{formatDate(pubDate)}</time>
  </div>
</article>
