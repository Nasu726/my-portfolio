---
import { NAV_ITEMS, SOCIAL_LINKS, SITE } from '../config';

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<div class="drawer-side z-40">
  <label for="my-drawer" aria-label="close sidebar" class="drawer-overlay"></label>

  <aside class="bg-base-100 border-r border-base-300 w-60 min-h-screen flex flex-col px-4 py-6">
    {/* ロゴ */}
    <a href="/" class="flex items-center gap-2 mb-8 px-2 group">
      <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center">
        <span class="text-white font-bold text-sm">n</span>
      </div>
      <span class="font-bold text-base-content group-hover:text-primary transition-colors text-sm">
        {SITE.author}
      </span>
    </a>

    {/* ナビゲーション */}
    <nav class="flex-1">
      <ul class="space-y-1">
        {NAV_ITEMS.map((item) => (
          <li>
            <a
              href={item.href}
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noopener noreferrer' : undefined}
              class:list={[
                'flex items-center px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                isActive(item.href)
                  ? 'bg-primary/10 text-primary'
                  : 'text-base-content/70 hover:text-base-content hover:bg-base-200',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    {/* ソーシャルリンク */}
    <div class="flex flex-wrap gap-1 pt-4 border-t border-base-300 mt-4">
      {SOCIAL_LINKS.map((link) => (
        <a
          href={link.url}
          target={link.url.startsWith('http') ? '_blank' : undefined}
          rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}
          aria-label={link.ariaLabel}
          title={link.ariaLabel}
          class="p-2 rounded-lg text-base-content/40 hover:text-base-content/80 hover:bg-base-200 transition-colors"
        >
          {link.iconSrc ? (
            <img
              src={link.iconSrc}
              alt={link.ariaLabel}
              class="w-4 h-4 opacity-50 hover:opacity-80"
              loading="lazy"
            />
          ) : (
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
              <path d={link.icon} />
            </svg>
          )}
        </a>
      ))}
    </div>
  </aside>
</div>
