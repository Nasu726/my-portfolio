---
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../lib/utils';
import { SITE } from '../config';
import type { MarkdownHeading } from 'astro';

interface Props {
  frontmatter: {
    title:       string;
    description: string;
    pubDate:     Date;
    heroImage?:  string;
    tags?:       string[];
  };
  ogImageOverride?: string;
  headings?:        MarkdownHeading[];
  readingTime?:     number;
}

const { frontmatter, ogImageOverride, headings = [], readingTime } = Astro.props;
const { title, description, pubDate, heroImage, tags = [] } = frontmatter;

const ogImage     = ogImageOverride || (heroImage?.trim() ? heroImage : SITE.defaultOgImage);
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

<BaseLayout {title} {description} {ogImage}>
  <article>
    <!-- ヒーロー画像 -->
    {heroImage?.trim() && (
      <img
        src={heroImage}
        alt={title}
        class="w-full max-h-64 object-contain rounded-xl mb-6"
        loading="eager"
      />
    )}

    <!-- タイトル -->
    <h1 class="text-2xl font-bold text-slate-900 mb-2">{title}</h1>

    <!-- メタ情報 -->
    <div class="flex items-center gap-2 text-sm text-slate-400 mb-3">
      <time>{formatDate(pubDate)}</time>
      {readingTime && (
        <>
          <span>·</span>
          <span>約 {readingTime} 分</span>
        </>
      )}
    </div>

    <!-- タグ -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-5">
        {tags.map(tag => (
          <a href={`/blog/tag/${tag}`}
            class="text-xs px-2.5 py-1 rounded-full border border-slate-200 text-slate-600 hover:border-indigo-300 hover:text-indigo-600 transition-colors"
          >#{tag}</a>
        ))}
      </div>
    )}

    <!-- 目次 -->
    {tocHeadings.length >= 2 && (
      <details class="mb-6 p-4 bg-slate-50 rounded-xl border border-slate-100" open>
        <summary class="cursor-pointer font-semibold text-sm text-slate-700 select-none">目次</summary>
        <nav class="mt-3 flex flex-col gap-1">
          {tocHeadings.map(h => (
            <a href={`#${h.slug}`}
              class:list={[
                'text-sm transition-colors hover:text-indigo-600',
                h.depth === 2 ? 'font-medium text-slate-600' : 'pl-4 text-slate-400 text-xs',
              ]}
            >{h.text}</a>
          ))}
        </nav>
      </details>
    )}

    <hr class="border-slate-100 mb-6" />

    <!-- 本文 -->
    <div class="prose prose-slate max-w-none prose-img:mx-auto prose-a:text-indigo-600 prose-headings:text-slate-800">
      <slot />
    </div>
  </article>

  <!-- コードブロックのコピーボタン -->
  <script>
    document.querySelectorAll('pre').forEach(block => {
      if (!block.parentNode) return;
      if (block.getAttribute('data-language') === 'mermaid' || block.classList.contains('mermaid')) return;

      const wrapper = document.createElement('div');
      wrapper.className = 'relative group mb-4';
      block.parentNode.insertBefore(wrapper, block);
      wrapper.appendChild(block);

      const btn = document.createElement('button');
      btn.className = 'absolute top-2 right-2 px-2 py-1 bg-slate-700/80 hover:bg-slate-600 text-white text-xs rounded opacity-0 group-hover:opacity-100 transition-opacity z-10';
      btn.textContent = 'Copy';

      btn.addEventListener('click', async () => {
        const code = block.querySelector('code')?.innerText || '';
        try {
          await navigator.clipboard.writeText(code);
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
        } catch {
          btn.textContent = 'Error';
        }
      });

      wrapper.appendChild(btn);
    });
  </script>
</BaseLayout>
