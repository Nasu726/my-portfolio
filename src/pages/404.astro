---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 Not Found" description="ページが見つかりません">
  <div class="flex flex-col items-center justify-center min-h-[50vh] text-center">
    <h1 class="text-8xl font-bold text-base-content/20 mb-4">404</h1>
    <p class="text-2xl font-semibold mb-2">ページが見つかりません</p>
    <p class="text-base-content/60 mb-8">お探しのページは存在しないか、移動した可能性があります。</p>
    <a href="/" class="btn btn-primary">ホームへ戻る</a>
  </div>
</BaseLayout>
