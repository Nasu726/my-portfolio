---
import type { CollectionEntry } from 'astro:content';
import { formatDate, isNew } from '../lib/utils';
import { SITE } from '../config';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const slug    = post.slug;
const showNew = isNew(pubDate);
---

{/*
  stretched-link パターン:
  外側 <article> を relative にして、非表示の <a> を absolute inset-0 で敷く。
  タグリンクは relative z-10 で上に出す。
*/}
<article class="group relative bg-white rounded-2xl border border-base-300 hover:border-primary/40 hover:shadow-md transition-all duration-200 p-5">
  {/* カード全体を覆うリンク（stretched link） */}
  <a href={`/blog/${slug}`} class="absolute inset-0 rounded-2xl z-0" aria-label={title}></a>

  {/* タイトル */}
  <h2 class="font-bold text-base leading-snug mb-2 group-hover:text-primary transition-colors line-clamp-2">
    {showNew && <span class="inline-block badge badge-primary badge-xs mr-1.5 align-middle">New</span>}
    {title}
  </h2>

  {/* 概要 */}
  <p class="text-sm text-base-content/60 line-clamp-2 mb-4">{description}</p>

  {/* タグ */}
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mb-4">
      {tags.map((tag) => (
        <a
          href={`/blog/tag/${tag}`}
          class="relative z-10 text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full hover:bg-primary/20 transition-colors"
        >
          #{tag}
        </a>
      ))}
    </div>
  )}

  {/* 著者行 */}
  <div class="flex items-center gap-2">
    <img
      src="/nasucat.webp"
      alt={SITE.author}
      class="w-6 h-6 rounded-full object-cover flex-shrink-0"
      loading="lazy"
    />
    <span class="text-xs text-base-content/60">{SITE.author}</span>
    <span class="text-xs text-base-content/30">·</span>
    <time class="text-xs text-base-content/50">{formatDate(pubDate)}</time>
  </div>
</article>
