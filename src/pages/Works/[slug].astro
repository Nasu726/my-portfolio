---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagBadge from '../../components/TagBadge.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const works = await getCollection('works', ({ data }) => !data.draft);
  return works.map((work) => ({ params: { slug: work.id }, props: { work } }));
}

const { work } = Astro.props;
const { Content, headings } = await render(work);

// 読了時間（コードブロック・数式を除いて 500文字 = 1分）
function readingTime(body: string): number {
  const cleaned = body
    .replace(/```[\s\S]*?```/g, '')
    .replace(/`[^`\n]+`/g, '')
    .replace(/\$\$[\s\S]*?\$\$/g, '')
    .replace(/\$[^$\n]+\$/g, '')
    .replace(/<[^>]+>/g, '')
    .replace(/^\s*\|.*\|\s*$/gm, ''); // Markdownテーブルを除外
  const chars = cleaned.replace(/\s+/g, '').length;
  return Math.max(1, Math.ceil(chars / 500));
}

const minutes = readingTime(work.body ?? '');
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

const dateStr = work.data.pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const links = work.data.links;
const ogImage = `/og/works/${work.id}.png`;
---

<BaseLayout
  title={work.data.title}
  description={work.data.description}
  ogImage={ogImage}
  useKatex
  wide
>
  <div class="lg:grid lg:grid-cols-[minmax(0,42rem)_15rem] lg:gap-10 lg:justify-center">
    <article class="max-w-2xl mx-auto lg:max-w-none lg:mx-0">
    <header class="mb-8">
      <div class="flex flex-wrap gap-1 mb-3">
        {work.data.tags.map((tag) => <TagBadge tag={tag} />)}
      </div>
      <h1 class="text-3xl font-bold text-gray-800 leading-tight">{work.data.title}</h1>
      <p class="mt-3 text-gray-500 text-sm leading-relaxed">{work.data.description}</p>
      <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-gray-400">
        <span>{dateStr}</span>
        <span>約 {minutes} 分で読めます</span>
      </div>

      <!-- 外部リンク -->
      {links && (
        <div class="mt-4 flex flex-wrap gap-2">
          {links.github && (
            <a
              href={links.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm bg-gray-100 hover:bg-gray-200 text-gray-700 transition-colors"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
              </svg>
              GitHub
            </a>
          )}
          {links.demo && (
            <a
              href={links.demo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm bg-purple-100 hover:bg-purple-200 text-purple-700 transition-colors"
            >
              作品のページ（{new URL(links.demo).hostname}） ↗
            </a>
          )}
          {links.article && (
            <a
              href={links.article}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm bg-blue-100 hover:bg-blue-200 text-blue-700 transition-colors"
            >
              記事を読む ↗
            </a>
          )}
        </div>
      )}
    </header>

    <!-- 目次（モバイル・タブレット用：本文上にインライン表示） -->
    {tocHeadings.length >= 2 && (
      <nav class="lg:hidden mb-8 px-5 py-4 bg-purple-50 rounded-xl border border-purple-100 text-sm">
        <p class="font-bold text-gray-700 mb-2">目次</p>
        <ol class="space-y-1">
          {tocHeadings.map(({ depth, slug, text }) => (
            <li style={`padding-left: ${(depth - 2) * 1.25}rem`}>
              <a
                href={`#${slug}`}
                class="text-purple-600 hover:text-purple-800 hover:underline transition-colors"
              >
                {text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )}

    <!-- 本文 -->
    <div
      class="prose prose-sm prose-gray max-w-none
        prose-headings:font-bold prose-headings:text-gray-800 prose-headings:scroll-mt-20
        prose-h2:text-xl prose-h3:text-lg
        prose-p:text-gray-700 prose-p:leading-relaxed
        prose-a:text-purple-600
        prose-strong:text-gray-800
        prose-code:text-purple-800 prose-code:bg-purple-50 prose-code:rounded
        prose-code:px-1 prose-code:py-0.5 prose-code:text-[0.85em]
        prose-code:before:content-none prose-code:after:content-none
        prose-pre:rounded-xl prose-pre:shadow-md
        prose-blockquote:border-l-purple-400 prose-blockquote:text-gray-600
        prose-blockquote:bg-purple-50/40 prose-blockquote:rounded-r
        prose-img:rounded-lg prose-img:mx-auto
        prose-table:text-sm prose-th:text-gray-700 prose-td:text-gray-600
        prose-hr:border-purple-100
      "
    >
      <Content />
    </div>

    <footer class="mt-12 pt-6 border-t border-purple-100">
      <a
        href="/Works"
        class="inline-block -m-3 p-3 text-sm text-purple-500 hover:text-purple-700 transition-colors"
      >
        ← 作品一覧に戻る
      </a>
    </footer>
    </article>

    <!-- 目次（PC全画面用：右の余白にスティッキー表示） -->
    {tocHeadings.length >= 2 && (
      <aside class="hidden lg:block">
        <nav class="sticky top-20 px-4 py-4 bg-purple-50 rounded-xl border border-purple-100 text-sm max-h-[calc(100vh-6rem)] overflow-y-auto">
          <p class="font-bold text-gray-700 mb-2">目次</p>
          <ol class="space-y-1">
            {tocHeadings.map(({ depth, slug, text }) => (
              <li style={`padding-left: ${(depth - 2) * 1.25}rem`}>
                <a
                  href={`#${slug}`}
                  class="text-purple-600 hover:text-purple-800 hover:underline transition-colors"
                >
                  {text}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      </aside>
    )}
  </div>
</BaseLayout>

<script>
  // コードブロックにコピーボタンを追加
  document.querySelectorAll('pre').forEach((pre) => {
    const btn = document.createElement('button');
    btn.className = 'copy-code-btn';
    btn.setAttribute('aria-label', 'コードをコピー');
    btn.textContent = 'コピー';
    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code');
      const text = code?.innerText ?? '';
      try {
        await navigator.clipboard.writeText(text);
        btn.textContent = 'コピー済み ✓';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = 'コピー';
          btn.classList.remove('copied');
        }, 2000);
      } catch {
        btn.textContent = '失敗';
        setTimeout(() => {
          btn.textContent = 'コピー';
        }, 2000);
      }
    });
    pre.classList.add('has-copy-btn');
    pre.appendChild(btn);
  });
</script>
