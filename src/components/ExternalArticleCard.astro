---
import type { ExternalArticle } from '../lib/externalArticles';
import { formatDate } from '../lib/utils';

interface Props {
  article: ExternalArticle;
}

const { article } = Astro.props;
const { title, description, pubDate, url, tags, source } = article;

const SOURCE_BADGE: Record<string, { label: string; cls: string }> = {
  qiita:      { label: 'Qiita',      cls: 'bg-green-50 text-green-700 border border-green-200' },
  hatenablog: { label: 'はてなブログ', cls: 'bg-sky-50  text-sky-700  border border-sky-200'   },
};

const badge = SOURCE_BADGE[source] ?? { label: source, cls: 'bg-slate-100 text-slate-600 border border-slate-200' };
---

<article class="group relative bg-white border border-slate-200 rounded-xl p-5 hover:border-indigo-200 hover:shadow-sm transition-all duration-150">
  <a href={url} target="_blank" rel="noopener noreferrer" class="absolute inset-0 rounded-xl" aria-label={title}></a>

  <div class="flex items-center justify-between gap-3 mb-2">
    <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${badge.cls}`}>{badge.label}</span>
    <svg class="w-3.5 h-3.5 flex-shrink-0 text-slate-300 group-hover:text-indigo-400 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
    </svg>
  </div>

  <h2 class="font-semibold text-slate-800 leading-snug mb-2 group-hover:text-indigo-600 transition-colors line-clamp-2">
    {title}
  </h2>

  {description && (
    <p class="text-sm text-slate-500 line-clamp-2 mb-3">{description}</p>
  )}

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-3">
      {tags.map(tag => (
        <a href={`/blog/tag/${tag}`} class="relative z-10 text-xs text-indigo-500 hover:text-indigo-700 transition-colors">
          #{tag}
        </a>
      ))}
    </div>
  )}

  <time class="text-xs text-slate-400">{formatDate(pubDate)}</time>
</article>
