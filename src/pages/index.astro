---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { fetchQiitaPosts } from '../lib/qiita';

const blogPosts = (await getCollection('blog', ({ data }) => !data.draft)).map((post) => ({
  title: post.data.title,
  description: post.data.description,
  pubDate: post.data.pubDate,
  tags: post.data.tags,
  href: `/Blog/${post.id}`,
  external: false,
  badge: undefined as string | undefined,
}));

const qiitaPosts = await fetchQiitaPosts();

const posts = [...blogPosts, ...qiitaPosts]
  .sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf())
  .slice(0, 4);

const works = (await getCollection('works', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const skills = [
  { category: '言語', tags: ['Python', 'C', 'MIPS'] },
  { category: 'フレームワーク', tags: ['Astro', 'React', 'TailwindCSS'] },
  { category: 'インフラ・ツール', tags: ['Linux', 'Docker', 'Cloudflare', 'Git', 'GitHub', 'VSCode'] },
];

const externalLinks = [
  {
    href: 'https://github.com/nasu726',
    label: 'GitHub',
