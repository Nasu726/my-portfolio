---
/**
 * 作品カードコンポーネントです。
 * カードクリックで projectUrl へ外部遷移（target="_blank"）します。
 *
 * Props: work: CollectionEntry<'works'>
 */
import type { CollectionEntry } from 'astro:content';
import { formatDate, isNew } from '../lib/utils';

interface Props {
  work: CollectionEntry<'works'>;
}

const { work } = Astro.props;
const { title, description, pubDate, projectUrl, badge, heroImage, tags } = work.data;
const showNew = isNew(pubDate);
---

<a
  href={projectUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="card card-side bg-base-100 border border-base-300 hover:border-secondary hover:shadow-md transition-all duration-200 group"
>
  {/* サムネイル画像（あれば） */}
  {heroImage && (
    <figure class="w-32 shrink-0">
      <img
        src={heroImage}
        alt={title}
        class="w-full h-full object-cover p-4"
        loading="lazy"
      />
    </figure>
  )}

  <div class="card-body py-4 px-5">
    {/* タイトル行 + New バッジ + badge */}
    <div class="flex items-start gap-2 flex-wrap">
      {showNew && (
        <span class="badge badge-primary badge-sm shrink-0 mt-1">New</span>
      )}
      {badge && (
        <span class="badge badge-secondary badge-sm shrink-0 mt-1">{badge}</span>
      )}
      <h2 class="card-title text-base font-bold leading-snug group-hover:text-secondary transition-colors">
        {title}
        {/* 外部リンクアイコン */}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 opacity-40 group-hover:opacity-70 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </h2>
    </div>

    {/* 概要 */}
    <p class="text-sm text-base-content/70 line-clamp-2">{description}</p>

    {/* 日付 + タグ */}
    <div class="flex flex-wrap items-center gap-2 mt-1">
      <time class="text-xs text-base-content/50">{formatDate(pubDate)}</time>
      {tags.map((tag) => (
        <a
          href={`/works/tag/${tag}`}
          class="badge badge-outline badge-sm hover:badge-secondary transition-colors"
          onclick="event.stopPropagation()"
        >
          #{tag}
        </a>
      ))}
    </div>
  </div>
</a>
