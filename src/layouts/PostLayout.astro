---
/**
 * ブログ記事個別ページのレイアウトです。
 * BaseLayout を内包し、記事タイトル・日付・タグなどのメタ情報を表示します。
 *
 * Props:
 *   frontmatter   - 記事のメタ情報（title, description, pubDate, heroImage?, tags?）
 *   ogImageOverride? - 動的 OGP 画像の URL（/og/blog/[slug].png）。
 *                      指定があればそれを使い、なければ heroImage、それもなければデフォルト画像を使う。
 */
import BaseLayout from './BaseLayout.astro';
import { formatDate } from '../lib/utils';
import { SITE } from '../config';

interface Props {
  frontmatter: {
    title:       string;
    description: string;
    pubDate:     Date;
    heroImage?:  string;
    tags?:       string[];
  };
  ogImageOverride?: string;
}

const { frontmatter, ogImageOverride } = Astro.props;
const { title, description, pubDate, heroImage, tags = [] } = frontmatter;

// OGP 画像の優先順位: ogImageOverride > heroImage > defaultOgImage
const ogImage = ogImageOverride || (heroImage && heroImage.trim() ? heroImage : SITE.defaultOgImage);
---

<BaseLayout {title} {description} {ogImage}>
  <article class="prose prose-base max-w-none prose-img:mx-auto prose-a:text-primary">
    {/* ヒーロー画像（あれば） */}
    {heroImage && heroImage.trim() && (
      <img
        src={heroImage}
        alt={title}
        class="w-full max-h-64 object-contain rounded-lg mb-6 not-prose"
        loading="eager"
      />
    )}

    {/* タイトル */}
    <h1 class="text-3xl font-bold mb-2 not-prose">{title}</h1>

    {/* 日付 */}
    <time class="text-sm text-base-content/50 not-prose block mb-3">
      {formatDate(pubDate)}
    </time>

    {/* タグバッジ */}
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-6 not-prose">
        {tags.map((tag) => (
          <a href={`/blog/tag/${tag}`} class="badge badge-outline hover:badge-primary transition-colors">
            #{tag}
          </a>
        ))}
      </div>
    )}

    <div class="divider not-prose my-4"></div>

    {/* 記事本文（MDX からレンダリングされたコンテンツ） */}
    <slot />
  </article>

  {/* コードブロックにコピーボタンを追加するスクリプト */}
  <script>
    document.querySelectorAll('pre').forEach((block) => {
      if (!block.parentNode) return;
      // Mermaid ブロックはスキップ
      if (block.getAttribute('data-language') === 'mermaid' || block.classList.contains('mermaid')) return;

      const wrapper = document.createElement('div');
      wrapper.className = 'relative group mb-4';
      block.parentNode.insertBefore(wrapper, block);
      wrapper.appendChild(block);

      const btn = document.createElement('button');
      btn.className = 'absolute top-2 right-2 px-2 py-1 bg-slate-700/80 hover:bg-slate-600 text-white text-xs rounded opacity-0 group-hover:opacity-100 transition-opacity z-10';
      btn.textContent = 'Copy';

      btn.addEventListener('click', async () => {
        const code = block.querySelector('code')?.innerText || '';
        try {
          await navigator.clipboard.writeText(code);
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
        } catch {
          btn.textContent = 'Error';
        }
      });

      wrapper.appendChild(btn);
    });
  </script>
</BaseLayout>
